generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================
// ГОРОДА
// =====================
model City {
  id                    Int       @id @default(autoincrement())
  slug                  String    @unique
  name                  String
  nameGenitive          String?
  namePrepositional     String?
  isActive              Boolean   @default(true)
  sortOrder             Int       @default(0)
  metaTitle             String?
  metaDescription       String?
  telegramChannelId     String?
  telegramChannelUsername String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  events                Event[]
  telegramPosts         TelegramPost[]

  @@index([isActive, sortOrder])
}

// =====================
// КАТЕГОРИИ
// =====================
model Category {
  id              Int       @id @default(autoincrement())
  slug            String    @unique
  name            String
  icon            String?
  sourceId        String?
  sortOrder       Int       @default(0)
  isActive        Boolean   @default(true)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  events          Event[]

  @@index([sourceId])
}

// =====================
// МЕРОПРИЯТИЯ
// =====================
model Event {
  id              Int          @id @default(autoincrement())
  externalId      String
  source          EventSource  @default(YANDEX_XML)
  slug            String
  title           String
  description     String?      @db.Text
  date            DateTime
  dateEnd         DateTime?
  place           String?
  price           Decimal?     @db.Decimal(10, 2)
  priceMax        Decimal?     @db.Decimal(10, 2)
  imageUrl        String?
  affiliateUrl    String?      @db.Text
  originalUrl     String?      @db.Text
  age             Int?
  isKids          Boolean      @default(false)
  isPremiere      Boolean      @default(false)
  isActive        Boolean      @default(true)
  isApproved      Boolean      @default(true)
  modifiedTime    BigInt?
  cityId          Int
  categoryId      Int
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  city            City         @relation(fields: [cityId], references: [id])
  category        Category     @relation(fields: [categoryId], references: [id])
  telegramPosts   TelegramPost[]

  @@unique([externalId, source])
  @@index([slug])
  @@index([cityId, date])
  @@index([cityId, categoryId, date])
  @@index([date])
  @@index([isActive, isApproved, date])
  @@index([cityId, isActive, isApproved, date])
}

enum EventSource {
  YANDEX_XML
  EXTERNAL_API
  MANUAL
}

// =====================
// TELEGRAM ПОСТЫ
// =====================
model TelegramPost {
  id            Int                @id @default(autoincrement())
  eventId       Int
  cityId        Int
  messageId     Int?
  channelId     String?
  status        TelegramPostStatus @default(PENDING)
  errorMessage  String?
  sentAt        DateTime?
  createdAt     DateTime           @default(now())

  event         Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  city          City               @relation(fields: [cityId], references: [id])

  @@unique([eventId, cityId])
  @@index([status])
  @@index([cityId, status])
}

enum TelegramPostStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

// =====================
// ЛОГИ ИМПОРТА
// =====================
model ImportLog {
  id            Int          @id @default(autoincrement())
  source        EventSource
  status        ImportStatus
  totalItems    Int          @default(0)
  newItems      Int          @default(0)
  updatedItems  Int          @default(0)
  skippedItems  Int          @default(0)
  errorItems    Int          @default(0)
  errors        Json?
  duration      Int?
  startedAt     DateTime     @default(now())
  finishedAt    DateTime?

  @@index([source, startedAt])
}

enum ImportStatus {
  RUNNING
  COMPLETED
  FAILED
}

// =====================
// НАСТРОЙКИ
// =====================
model Setting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt
}

// =====================
// ПОЛЬЗОВАТЕЛИ
// =====================
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String?
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

enum UserRole {
  ADMIN
  MODERATOR
  USER
}
